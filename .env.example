# Gemini / Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-east1

# Workspace OAuth (from setup-gcp.sh output)
WORKSPACE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
WORKSPACE_CLOUD_FUNCTION_URL=https://your-cloud-function-url.a.run.app
